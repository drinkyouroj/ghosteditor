# Database
DATABASE_URL=postgresql+asyncpg://ghosteditor:ghosteditor_dev@localhost:5433/ghosteditor

# Redis
REDIS_URL=redis://localhost:6380/0

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM API
LLM_BACKEND=groq                   # "anthropic", "openai", or "groq"
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_BASE_URL=                # Leave empty for Anthropic default
OPENAI_API_KEY=                    # For OpenAI or local models (use "none" for local)
OPENAI_BASE_URL=                   # e.g. http://localhost:11434/v1 for Ollama
GROQ_API_KEY=                      # Groq API key for fast inference
LLM_MODEL_BIBLE=llama-3.3-70b-versatile
LLM_MODEL_ANALYSIS=llama-3.3-70b-versatile

# AWS S3 / MinIO
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=ghosteditor-manuscripts
AWS_REGION=us-east-1
S3_ENDPOINT_URL=http://localhost:9002  # Remove for production AWS S3

# Email (Resend)
RESEND_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
