# Database
DATABASE_URL=postgresql+asyncpg://ghosteditor:ghosteditor_dev@localhost:5433/ghosteditor

# Redis
REDIS_URL=redis://localhost:6380/0

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM API
LLM_BACKEND=anthropic              # "anthropic", "openai", or "groq"
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_BASE_URL=                # Leave empty for Anthropic default
OPENAI_API_KEY=                    # For OpenAI or local models (use "none" for local)
OPENAI_BASE_URL=                   # e.g. http://localhost:11434/v1 for Ollama
GROQ_API_KEY=                      # Groq API key for fast inference
LLM_MODEL_BIBLE=claude-haiku-4-5-20251001       # For Groq: openai/gpt-oss-120b (100% eval pass rate)
LLM_MODEL_ANALYSIS=claude-haiku-4-5-20251001    # For Groq: openai/gpt-oss-120b (100% eval pass rate)
LLM_MODEL_SPLITTING=                             # For Groq: llama-3.1-8b-instant (fast/cheap for structure detection)

# Worker
# ARQ_JOB_TIMEOUT=3600  # Seconds. For cloud LLMs (Groq/Anthropic), 600 is sufficient. For local models, keep at 3600.

# AWS S3 / MinIO
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=ghosteditor-manuscripts
AWS_REGION=us-east-1
S3_ENDPOINT_URL=http://localhost:9002  # Remove for production AWS S3

# Email (Resend)
RESEND_API_KEY=

# Dev overrides
# RATE_LIMIT_EXEMPT_EMAILS=dev@ghosteditor.com   # Comma-separated, bypass upload rate limits
# AUTO_PAID_EMAILS=dev@ghosteditor.com            # Comma-separated, manuscripts auto-marked as paid

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
