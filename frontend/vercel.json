{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/auth/:path*", "destination": "https://ghosteditor-api-production.up.railway.app/auth/:path*" },
    { "source": "/manuscripts/:path*", "destination": "https://ghosteditor-api-production.up.railway.app/manuscripts/:path*" },
    { "source": "/bible/:path*", "destination": "https://ghosteditor-api-production.up.railway.app/bible/:path*" },
    { "source": "/argument-map/:path*", "destination": "https://ghosteditor-api-production.up.railway.app/argument-map/:path*" },
    { "source": "/stripe/:path*", "destination": "https://ghosteditor-api-production.up.railway.app/stripe/:path*" },
    { "source": "/health", "destination": "https://ghosteditor-api-production.up.railway.app/health" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ]
}
