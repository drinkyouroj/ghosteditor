# Postgres (used internally by docker-compose — no external port needed)
POSTGRES_PASSWORD=change-me-use-a-strong-password

# Backend exposed port (pick an unused port on the host)
BACKEND_PORT=8000

# JWT
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32

# Claude API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Cloudflare R2
AWS_ACCESS_KEY_ID=your-r2-access-key
AWS_SECRET_ACCESS_KEY=your-r2-secret-key
S3_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
S3_BUCKET_NAME=ghosteditor
AWS_REGION=auto

# Frontend URL (for CORS and email links)
BASE_URL=https://your-frontend-domain.com

# Email (Resend)
RESEND_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
